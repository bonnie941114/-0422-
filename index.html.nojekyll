<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>卓配鏡 21 歲生日快樂！ - 蛋糕慶生版</title>
    <link href="https://fonts.googleapis.com/css2?family=ZCOOL+Kuaile&family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #050508;
            --sakura: #fdeff2;    
            --usubeni: #e87a90;   
            --y2k-pink: #ff00ff;  
            --meta-blue: #33ffff; 
            --gold: #ffd700;
        }

        html, body {
            margin: 0; padding: 0;
            width: 100%; height: 100%;
            overflow: hidden;
            display: flex; justify-content: center; align-items: center;
            background-color: var(--bg-dark);
            font-family: 'Press Start 2P', 'ZCOOL Kuaile', sans-serif;
            -webkit-tap-highlight-color: transparent;
        }

        /* 掃描線效果 */
        .scanlines {
            position: absolute; width: 100%; height: 100%;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%);
            background-size: 100% 4px; z-index: 20; pointer-events: none;
        }

        /* 霓虹發光外框 */
        .frame-glow {
            padding: 8px;
            background: linear-gradient(90deg, var(--y2k-pink), var(--meta-blue));
            border-radius: 15px;
            box-shadow: 0 0 25px rgba(255, 0, 255, 0.4);
            z-index: 10;
        }

        .card {
            width: 90vw; max-width: 800px; height: 420px;
            background: rgba(15, 15, 20, 0.98);
            border: 3px solid #fff; border-radius: 10px;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            position: relative; overflow: hidden;
        }

        /* 標題需求：同一行 + 漸層內容 + 凹凸效果 */
        .title-line {
            width: 100%;
            display: flex; justify-content: center; align-items: center;
            white-space: nowrap; /* 強制不換行 */
            font-size: clamp(1.1rem, 4.5vw, 1.8rem); /* 根據螢幕自動縮放 */
            font-weight: 900;
            margin-bottom: 25px;
            letter-spacing: 2px;
        }

        .gradient-name {
            background: linear-gradient(to bottom, var(--sakura), var(--usubeni));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            filter: drop-shadow(4px 4px 0px #000);
        }

        .hbd-white {
            color: #fff;
            filter: drop-shadow(4px 4px 0px #000);
            margin-left: 10px;
        }

        /* 祝福內文 */
        .message-box {
            color: #ccc; font-size: 10px; line-height: 2;
            text-align: center; margin-bottom: 30px;
            width: 85%; white-space: normal;
        }

        /* 🎂 新機關：像素生日蛋糕 (取代星星) */
        .cake-box {
            width: 80px; height: 80px; margin-bottom: 20px;
            position: relative; display: flex; justify-content: center; align-items: center;
        }
        .main-cake {
            font-size: 50px; opacity: 0.3; transition: 0.5s; color: #444;
            filter: grayscale(1);
        }

        /* 當卡片被點擊後 (active) 觸發蛋糕機關 */
        .card.active .main-cake {
            opacity: 1; filter: grayscale(0);
            transform: scale(1.5);
            animation: cakeBounce 1.5s infinite alternate, cakeGlow 1s infinite alternate;
        }

        @keyframes cakeBounce {
            from { transform: scale(1.5); }
            to { transform: scale(1.7); }
        }
        @keyframes cakeGlow {
            from { filter: drop-shadow(0 0 10px var(--sakura)); }
            to { filter: drop-shadow(0 0 25px var(--gold)); }
        }

        /* 點擊提示 */
        .click-hint {
            color: var(--gold); font-size: 9px; border: 1px solid var(--gold);
            padding: 10px 25px; border-radius: 30px; animation: blink 1s infinite;
        }
        @keyframes blink { 50% { opacity: 0; } }

        /* 隱藏原生播放器 */
        #hbd-audio { display: none; }
    </style>
</head>
<body id="body-area">

    <div class="scanlines"></div>

    <audio id="hbd-audio" loop preload="auto">
        <source src="https://cdn.pixabay.com/audio/2022/11/24/audio_3490710609.mp3" type="audio/mpeg">
    </audio>

    <div class="frame-glow" id="trigger-area">
        <div class="card" id="main-card">
            
            <div class="cake-box">
                <div class="main-cake">🎂</div>
            </div>
            
            <div class="title-line">
                <span class="gradient-name">卓配鏡</span>
                <span class="hbd-white">生日快樂！！！</span>
            </div>

            <div class="message-box">
                就這樣 21 歲了，突然覺得認識好久了<br>
                祝 老闆前額葉杏仁核發展完完整整<br>
                教授咪挺什麼都過，開開心心跟我度過女人。
            </div>

            <div class="click-hint" id="hint">▶ TOUCH SCREEN TO LIGHT THE CANDLE ◀</div>
        </div>
    </div>

    <script>
        const audio = document.getElementById('hbd-audio');
        const card = document.getElementById('main-card');
        const hint = document.getElementById('hint');

        // 手機版音訊解鎖核心 Function
        function startBirthdayParty() {
            // 每次點擊先解鎖音訊
            audio.play().then(() => {
                // 成功播放
                card.classList.add('active');
                hint.style.display = 'none';
            }).catch(error => {
                console.log("Audio play failed", error);
                // 如果失敗（可能是靜音模式），這裡至少能觸發視覺
                card.classList.add('active');
                hint.innerText = "請開聲音以聽到音樂";
            });
        }

        // 針對 iOS 額外增加手指碰觸解鎖
        document.body.addEventListener('touchstart', function() {
            audio.load();
        }, { once: true });

        // 綁定點擊事件
        document.getElementById('trigger-area').addEventListener('click', startBirthdayParty);
    </script>
</body>
</html>
